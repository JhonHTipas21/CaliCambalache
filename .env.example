# ═══════════════════════════════════════════
# CaliCambalache — Variables de Entorno
# Copiar este archivo a .env y rellenar valores
# ═══════════════════════════════════════════

# ── Firebase (Frontend SDK) ──
FIREBASE_API_KEY=tu_api_key_aqui
FIREBASE_AUTH_DOMAIN=tu_proyecto.firebaseapp.com
FIREBASE_PROJECT_ID=tu_proyecto_id
FIREBASE_STORAGE_BUCKET=tu_proyecto.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef

# ── Firebase Admin (Backend — ruta al service account JSON) ──
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# ── Servidor Backend ──
PORT=3000
NODE_ENV=development

# ── CORS (dominios permitidos, separados por coma) ──
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500

# ── JWT Auth (NestJS — nuevas variables para el módulo de autenticación) ──
JWT_SECRET=reemplazar_con_clave_aleatoria_de_minimo_64_caracteres
JWT_REFRESH_SECRET=reemplazar_con_otra_clave_distinta_de_minimo_64_caracteres
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d
